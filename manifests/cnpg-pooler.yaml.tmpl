apiVersion: postgresql.cnpg.io/v1
kind: Pooler
metadata:
  name: ${CNPG_CLUSTER_NAME}-pooler-rw
  namespace: ${CNPG_NAMESPACE}
spec:
  cluster:
    name: ${CNPG_CLUSTER_NAME}
  instances: 2
  type: rw
  pgbouncer:
    poolMode: session
    parameters:
      max_client_conn: "200"
      default_pool_size: "25"
