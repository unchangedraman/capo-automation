# =========================================================================
# CAPO + CNPG portable automation config.
#
# Fill in all CHANGE_ME_* values for your target OpenStack cloud, then run:
#   ./install-prereqs.sh
#   ./install-mgmt-cluster.sh
#   ./bootstrap-openstack-resources.sh   # optional: auto-create flavors/keypair
#   ./create-cluster.sh
#   ./post-bootstrap.sh
#
# Keep this file out of git if you fill in real credentials. A local override
# pattern: cp config.env config.prod.env  → CONFIG_FILE=config.prod.env ./script
# The .gitignore excludes config.*.env by default.
# =========================================================================

# --- OpenStack auth ---
OS_AUTH_URL=CHANGE_ME_HTTPS_KEYSTONE_URL        # e.g. https://keystone.example.com:5000/v3
OS_USERNAME=CHANGE_ME_USERNAME
OS_PASSWORD=CHANGE_ME_PASSWORD
OS_PROJECT_NAME=CHANGE_ME_PROJECT
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=CHANGE_ME_REGION                 # e.g. RegionOne
OS_INTERFACE=public

# --- Cluster provisioning (CAPO) ---
CLUSTER_NAME=my-k8s-cluster                     # change to taste
CLOUD_NAME=openstack
EXTERNAL_NETWORK_ID=CHANGE_ME_EXTERNAL_NET_UUID # openstack network list --external -c ID -f value
NODE_CIDR=10.6.0.0/24                           # subnet CAPO will create for the cluster
POD_CIDR=10.244.0.0/16                          # pod network, in-cluster only
CP_FLAVOR=k8s.cp.v2                             # 2 vCPU / 4 GB / 20 GB (bootstrap-openstack-resources.sh creates this)
WORKER_FLAVOR=k8s.worker.v2                     # same specs; used for worker nodes
IMAGE_NAME=ubuntu-24.04-k8s-1.29                # Glance image name (must be kubeadm-ready)
SSH_KEY_NAME=capo-key                           # OpenStack keypair name
K8S_VERSION=v1.29.15
CP_REPLICAS=1                                   # control-plane replicas (3 for HA)
WORKER_REPLICAS=2

# --- CNI (Cilium) ---
CILIUM_VERSION=1.16.5
CILIUM_KUBE_PROXY_REPLACEMENT=false             # true => disable kube-proxy, run pure eBPF
CILIUM_TUNNEL_PROTOCOL=vxlan                    # vxlan | geneve | disabled (native routing)
CILIUM_HUBBLE_ENABLED=true

# --- CNPG ---
CNPG_VERSION=1.24.1
CNPG_NAMESPACE=app-db
CNPG_CLUSTER_NAME=pg-cluster
CNPG_INSTANCES=3
CNPG_MIN_SYNC=1
CNPG_MAX_SYNC=1
STORAGE_CLASS=cinder-csi                        # name the post-bootstrap script creates
STORAGE_SIZE=10Gi
PG_IMAGE=ghcr.io/cloudnative-pg/postgresql:17.0
DB_NAME=appdb
DB_OWNER=appdb
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_WAL_KEEP_SIZE=512MB
PG_CPU_REQUEST=250m
PG_MEM_REQUEST=512Mi
PG_CPU_LIMIT=1000m
PG_MEM_LIMIT=1Gi

# --- Management-cluster bootstrap ---
MGMT_CLUSTER_NAME=capi-mgmt
KIND_VERSION=v0.27.0
KUBECTL_VERSION=v1.29.15
CLUSTERCTL_VERSION=v1.6.3
HELM_VERSION=v3.20.1
